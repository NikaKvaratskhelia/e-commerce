// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// enums ===========================================

enum user_role {
  admin
  user
}

// models ===========================================

model User {
  id            String    @id @unique @default(uuid())
  name          String
  username      String    @unique
  email         String    @unique
  password      String
  role          user_role @default(user)
  emailVerified Boolean   @default(false)

  // relations
  cart     Cart?
  comments Comment[]
  likes    Like[]

  // auth sessions
  sessions Session[]
  replies  Reply[]
  orders   Order[]
  wishlist Wishlist?
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerifyEmail {
  id        String   @id @default(uuid())
  userEmail String   @unique
  code      Int
  expiresAt DateTime
}

model Product {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  price       Float
  thumbnail   String
  stock       Int      @default(0)
  createdAt   DateTime @default(now())

  // relations
  colors            ProductColor[]
  discounts         Discount[]
  productCategory   ProductCategory @relation(fields: [productCategoryId], references: [id], onDelete: Cascade)
  productCategoryId Int
  cartItems         CartItem[]
  comments          Comment[]
}

model ProductCategory {
  id            Int       @id @default(autoincrement())
  title         String    @unique
  categoryPhoto String
  products      Product[]
}

model ProductColor {
  id    Int     @id @default(autoincrement())
  color String
  has3D Boolean @default(false)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  photos    ProductPhoto[]
  model3d   Product3D?
  cartItems CartItem[]

  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
}

model ProductPhoto {
  id  Int    @id @default(autoincrement())
  url String

  colorId Int
  color   ProductColor @relation(fields: [colorId], references: [id], onDelete: Cascade)
}

model Product3D {
  id  Int    @id @default(autoincrement())
  url String

  colorId Int          @unique
  color   ProductColor @relation(fields: [colorId], references: [id], onDelete: Cascade)
}

model Discount {
  id                 Int      @id @default(autoincrement())
  discountPercentage Float
  discountEndDate    DateTime

  // relations
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Blog {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  thumbnail String
  createdAt DateTime @default(now())
}

model Cart {
  id    String @id @default(uuid())
  total Float  @default(0)

  // relations
  cartItems CartItem[]
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CartItem {
  id       Int @id @default(autoincrement())
  quantity Int

  productColorId Int
  productColor   ProductColor @relation(fields: [productColorId], references: [id], onDelete: Cascade)

  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id])
  productId Int?

  @@unique([productColorId, cartId])
}

model Comment {
  id      Int    @id @default(autoincrement())
  content String
  rating  Int

  userId String
  author User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  prodcutId Int
  product   Product @relation(fields: [prodcutId], references: [id], onDelete: Cascade)

  likes   Like[]
  replies Reply[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Like {
  id Int @id @default(autoincrement())

  userId String
  author User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  commentId Int
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, commentId])
}

model Reply {
  id      Int    @id @default(autoincrement())
  content String

  userId String
  author User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  commentId Int
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  paymentMethod String
  total         Float
  // relations

  userId     String
  user       User        @relation(references: [id], fields: [userId], onDelete: Cascade)
  orderItems OrderItem[]
}

model OrderItem {
  id       Int @id @default(autoincrement())
  quantity Int

  // relations
  orderId String
  order   Order  @relation(references: [id], fields: [orderId], onDelete: Cascade)

  producColortId Int
  productColor   ProductColor @relation(fields: [producColortId], references: [id])
}

model Wishlist {
  id Int @id @default(autoincrement())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  wishlistItems WishlistItem[]
}

model WishlistItem {
  id Int @id @default(autoincrement())

  wishlistId Int
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)

  productColorId Int
  productColor   ProductColor @relation(references: [id], fields: [productColorId], onDelete: Cascade)

  @@unique([wishlistId, productColorId])
}
